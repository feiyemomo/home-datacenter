# ---- Runtime data / secrets (never commit) ----
# SQLite database + mosquitto persistence hold live state and (in the
# DB's case) AccessKey hashes + user identities.
/data/
/.env
.env.local

# Local config override holds the real jwt.secret; never commit it.
services/api/configs/config.local.yaml

# ---- IDE / OS ----
.vscode/
.idea/
.DS_Store
Thumbs.db

# ---- Go ----
services/api/server
services/api/cmd.exe
services/api/*.exe
*.test
*.out

# ---- Node / web ----
web/node_modules/
web/dist/
web/.npm-cache/
web/.npm-prefix/
web/tsconfig.tsbuildinfo
web/tsconfig.node.tsbuildinfo

# ---- Build artifacts & iteration leftovers ----
# Go2rtc HLS keepalive patch iteration: OCI image extracts, tarballs,
# and intermediate binaries. The canonical build product is the
# `home-datacenter-go2rtc` Docker image (see deploy/go2rtc/Dockerfile).
# These directories are kept locally as scratch during a build, but
# must never be committed.
go2rtc-extract/
go2rtc-new/
go2rtc-v2/
go2rtc-*.tar
go2rtc-newly-built

# Ad-hoc build logs from the go2rtc patch iteration. Useful for
# bisecting a regression, but the canonical log is scripts/
# (added on demand). Generated as `build_*.log`.
build_*.log

# Live JWT for ad-hoc curl tests. NEVER commit — rotate immediately
# if this file leaks (see docs/security.md).
.token.txt
