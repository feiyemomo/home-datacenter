# Home Datacenter — environment variables example
#
# Copy to .env and adjust values. docker compose automatically loads
# a .env file in the same directory. The .env file is gitignored —
# never commit it.

# ---- API service ----
# Override the config file path (default: configs/config.yaml)
APP_CONFIG=/configs/config.yaml

# ---- JWT signing secret (REQUIRED) ----
# The API refuses to start without a 32+ char secret. Generate with:
#   openssl rand -hex 32
# This overrides jwt.secret in configs/config.yaml.
JWT_SECRET=your-secret-key

# ---- MQTT broker auth ----
# The API server authenticates to Mosquitto with this username/password.
# allow_anonymous=false in deploy/mosquitto/mosquitto.conf, so these
# MUST be set. The matching password entry must exist in
# deploy/mosquitto/passwd (create with mosquitto_passwd).
MQTT_BROKER=tcp://mosquitto:1883
MQTT_CLIENT_ID=home-datacenter
MQTT_USERNAME=home-datacenter
MQTT_PASSWORD=
MQTT_QOS=1

# ---- WebSocket ----
WS_PATH=/api/v1/ws
WS_HEARTBEAT_SECONDS=30

# ---- Database ----
DB_PATH=/data/sqlite/app.db

# ---- Server ----
SERVER_PORT=8080

# ---- Local dev: host port to expose Mosquitto on (optional) ----
# Only used if you uncomment the mosquitto ports mapping in compose.yaml.
# MQTT_BIND_PORT=1883

# ---- go2rtc (Phase 4: camera platformization) ----
# The home-api service pushes RTSP sources to this address and uses
# it as a WebRTC/HLS origin. The default (http://home-go2rtc:1984)
# is reachable from inside the Docker network. Override only if
# you run go2rtc on the host or a different host.
GO2RTC_BASE_URL=http://home-go2rtc:1984
